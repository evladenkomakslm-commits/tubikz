# --- БД (Postgres) ---
# Локально: docker-compose up -d или Neon URL
# Production (Render): pooled Neon URL — host содержит "-pooler"
DATABASE_URL="postgresql://user:pass@localhost:5432/tubikz"
# Direct (non-pooled) Neon URL — нужен только для prisma migrate.
# В Neon Dashboard выключи "Pooled connection" и скопируй (host без "-pooler").
DIRECT_URL="postgresql://user:pass@localhost:5432/tubikz"

# --- Auth (NextAuth) ---
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Storage (UploadThing) ---
# Если не задан — uploads сохраняются локально в public/uploads (только dev)
UPLOADTHING_TOKEN=""

# --- Web Push (VAPID) ---
# Сгенерить: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# --- Server ---
PORT=3000
