// Tubikz schema (PostgreSQL).
// Локально можно использовать docker postgres или Neon (тот же URL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App runtime uses the pooled URL (PgBouncer in transaction mode).
  url       = env("DATABASE_URL")
  // Migrations need a direct connection — PgBouncer's transaction pooling
  // breaks Prisma's advisory-lock handshake and `migrate deploy` times out.
  // Set DIRECT_URL to the un-pooled Neon connection string (host without
  // `-pooler`). If unset, Prisma falls back to `url`.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  bio           String?
  isOnline      Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sentMessages     Message[]      @relation("MessageSender")
  conversations    Participant[]
  sentRequests     FriendRequest[] @relation("RequestFrom")
  receivedRequests FriendRequest[] @relation("RequestTo")
  friendsOf        Friendship[]    @relation("FriendshipOwner")
  friends          Friendship[]    @relation("FriendshipFriend")
  readReceipts     MessageRead[]
  reactions        MessageReaction[]
  outgoingCalls    Call[]         @relation("CallCaller")
  incomingCalls    Call[]         @relation("CallCallee")
  invitesCreated   InviteCode[]   @relation("InviteCreator")
  inviteUsed       InviteCode?    @relation("InviteUsedBy")
  totp             TotpSecret?
  sessions         ActiveSession[]

  @@index([username])
  @@index([email])
}

/// Pre-generated codes that gate registration. Admin generates → shares with friend → friend uses on /register.
model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  note        String?   // optional human label, e.g. "for Sasha"
  createdById String?
  usedById    String?   @unique
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  createdBy User? @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  usedBy    User? @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([code])
}

/// TOTP (Google Authenticator) secret for 2FA. One per user.
model TotpSecret {
  id        String   @id @default(cuid())
  userId    String   @unique
  secret    String   // base32-encoded
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  enabledAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// One row per active login session (per device/browser). JWT carries jti; on every
/// authenticated request we check the row exists. "Logout other devices" deletes rows.
model ActiveSession {
  id           String   @id @default(cuid())
  userId       String
  jti          String   @unique // JWT ID
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model FriendRequest {
  id         String        @id @default(cuid())
  fromUserId String
  toUserId   String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  fromUser User @relation("RequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("RequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
}

model Friendship {
  id        String   @id @default(cuid())
  ownerId   String
  friendId  String
  createdAt DateTime @default(now())

  owner  User @relation("FriendshipOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([ownerId, friendId])
  @@index([ownerId])
}

enum ConversationType {
  DIRECT
  GROUP
  SAVED
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType @default(DIRECT)
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  participants Participant[]
  messages     Message[]
  calls        Call[]

  @@index([updatedAt])
}

model Participant {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  FILE
  CALL
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  CONNECTING
  ACTIVE
  ENDED
  MISSED
  DECLINED
  FAILED
}

model Call {
  id             String     @id @default(cuid())
  conversationId String
  callerId       String
  calleeId       String
  type           CallType   @default(AUDIO)
  status         CallStatus @default(RINGING)
  startedAt      DateTime   @default(now())
  answeredAt     DateTime?
  endedAt        DateTime?
  durationMs     Int?
  endReason      String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  caller       User         @relation("CallCaller", fields: [callerId], references: [id], onDelete: Cascade)
  callee       User         @relation("CallCallee", fields: [calleeId], references: [id], onDelete: Cascade)

  @@index([conversationId, startedAt])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  content        String?
  mediaUrl       String?
  mediaMimeType  String?
  durationMs     Int?
  callId         String?
  replyToId      String?
  createdAt      DateTime    @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  reads        MessageRead[]
  reactions    MessageReaction[]
  replyTo      Message?           @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]          @relation("MessageReply")

  @@index([conversationId, createdAt])
  @@index([replyToId])
}

/// Per-user emoji reactions on a message. Telegram-style — same user
/// + same emoji is unique (toggle); different emoji adds another row.
model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}
